
#1. Sample tuple of hours parked for each car
hours_parked = (2, 5, 3, 1)
bill = []
cost = 50  # base rate per hour

for h in hours_parked:
    if h <= 2:
        c = 2 * cost
    elif h <= 5:
        extra = h - 2
        c = 2 * cost + extra * 100
    else:
        extra = h - 5
        c = 2 * cost + 3 * 100 + extra * 150
    bill.append(c)

print("Car Parking Bill per car:", bill)
print("Total Bill:", sum(bill))
print()
#sample output
