
-- Single Row Subqueries

-- Q1: Find students who scored more than the average marks of all students
SELECT *
FROM students
WHERE marks > (SELECT AVG(marks) FROM students);

-- Q2: Display employees whose salary is greater than the minimum salary in the company
SELECT *
FROM employees
WHERE salary > (SELECT MIN(salary) FROM employees);

-- Q3: Find the student(s) who scored the highest marks in the class
SELECT *
FROM students
WHERE marks = (SELECT MAX(marks) FROM students);


-- Multiple Row Subqueries


-- Q4: Find students who belong to departments located in 'Hyderabad'
SELECT *
FROM students
WHERE department IN (
    SELECT department_id
    FROM departments
    WHERE location = 'Hyderabad'
);

-- Q5: Display employees who work in departments named 'HR' or 'Sales'
SELECT *
FROM employees
WHERE department_id IN (
    SELECT department_id
    FROM departments
    WHERE department_name IN ('HR', 'Sales')
);

-- Q6: Find customers who placed orders with an amount greater than 10,000
SELECT *
FROM customers
WHERE customer_id IN (
    SELECT customer_id
    FROM orders
    WHERE amount > 10000
);

-- Multiple Column Subqueries

-- Q7: Find students who have the same department and marks as student with ID = 3
SELECT *
FROM students
WHERE (department, marks) = (
    SELECT department, marks
    FROM students
    WHERE id = 3
);

-- Q8: Display employees who have the same salary and department_id as employee with emp_id = 5
SELECT *
FROM employees
WHERE (salary, department_id) = (
    SELECT salary, department_id
    FROM employees
    WHERE emp_id = 5
);


-- Nested Subqueries

-- Q9: Find employees who earn more than the average salary of the department that has the highest number of employees
SELECT *
FROM employees
WHERE salary > (
    SELECT AVG(salary)
    FROM employees
    WHERE department_id = (
        SELECT department_id
        FROM employees
        GROUP BY department_id
        ORDER BY COUNT(emp_id) DESC
        LIMIT 1
    )
);

-- Q10: Find students who scored more than the average marks of the department which has the highest average marks
SELECT *
FROM students
WHERE marks > (
    SELECT MAX(avg_marks)
    FROM (
        SELECT AVG(marks) AS avg_marks
        FROM students
        GROUP BY department
    ) AS dept_avg
);


-- Correlated Subqueries


-- Q11: Find students who scored more than the average marks of their own department
SELECT *
FROM students s1
WHERE marks > (
    SELECT AVG(marks)
    FROM students s2
    WHERE s2.department = s1.department
);

-- Q12: Display employees who earn more than the average salary in their department
SELECT *
FROM employees e1
WHERE salary > (
    SELECT AVG(salary)
    FROM employees e2
    WHERE e2.department_id = e1.department_id
);

-- Q13: Find customers who placed more than one order
SELECT *
FROM customers c
WHERE (
    SELECT COUNT(*)
    FROM orders o
    WHERE o.customer_id = c.customer_id
) > 1;
